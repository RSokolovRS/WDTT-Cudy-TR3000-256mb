#!/bin/sh
# WDTT selective routing — OpenWrt 25 / fw4
# WDTT_ROUTING_VERSION=3.7.3
# dnsmasq nftset → nft sets → fwmark → ip rule table 100 → wg-wdtt

. /lib/functions.sh

MARK=0x777474
TABLE=100
IFACE="${2:-wg-wdtt}"

NFT_TABLE=wdtt
NFT_SET_ROUTE=wdtt_route
NFT_SET_EXCL=wdtt_excl
NFT_SET_SRC=wdtt_src
NFT_FAMILY=inet

DNSMASQ_SNIPPET=/tmp/dnsmasq.d/wdtt.conf
STATE_DIR=/var/run/wdtt
NFT_HOOK="$STATE_DIR/wdtt.nft"
NFT_HOOK_LEGACY="/etc/nftables.d/99-wdtt.nft"

log() { logger -t wdtt-routing "$*"; }

ensure_dnsmasq_confdir() {
	[ -x /sbin/uci ] || return 0
	uci -q get dhcp.@dnsmasq[0] >/dev/null 2>&1 || return 0
	if ! uci -q get dhcp.@dnsmasq[0].confdir 2>/dev/null | grep -qF '/tmp/dnsmasq.d'; then
		uci -q add_list dhcp.@dnsmasq[0].confdir='/tmp/dnsmasq.d' 2>/dev/null
		uci -q commit dhcp 2>/dev/null
		log "dnsmasq confdir: added /tmp/dnsmasq.d"
	fi
}

check_dnsmasq_nftset() {
	if ! command -v dnsmasq >/dev/null 2>&1; then
		log "ERROR: dnsmasq not found"
		echo "ERROR: dnsmasq not found" >&2
		return 1
	fi
	if dnsmasq --version 2>/dev/null | grep -qi nftset; then
		return 0
	fi
	log "ERROR: dnsmasq без nftset — apk add dnsmasq-full"
	echo "ERROR: dnsmasq-full required for selective routing (nftset)" >&2
	return 1
}

_resolve_via_dnsmasq() {
	local domain="$1"
	if command -v dig >/dev/null 2>&1; then
		dig +time=2 +tries=1 +short "@127.0.0.1" "$domain" A 2>/dev/null | grep -E '^[0-9]+\.' | head -n1
		return 0
	fi
	nslookup "$domain" 127.0.0.1 2>/dev/null | awk '/^Address [0-9]/ { print $2; exit }'
}

warmup_nftset_domains() {
	local domain line warmed=0 ip

	[ -f "$DNSMASQ_SNIPPET" ] || return 0
	while read -r line; do
		domain="${line#nftset=/}"
		domain="${domain%%/*}"
		[ -n "$domain" ] || continue
		ip="$(_resolve_via_dnsmasq "$domain")"
		if [ -n "$ip" ]; then
			warmed=$((warmed + 1))
			log "warmup dns: ${domain} -> ${ip}"
		else
			log "WARN: warmup dns failed: ${domain}"
		fi
	done <<EOF
$(grep '^nftset=' "$DNSMASQ_SNIPPET" 2>/dev/null)
EOF
	log "warmup: ${warmed} domain(s) resolved into nftset"
}

NFTSET_SUFFIX="4#${NFT_FAMILY}#${NFT_TABLE}#"

normalize_domain() {
	local d="$1"
	d="${d#https://}"
	d="${d#http://}"
	d="${d%%/*}"
	d="${d%/}"
	printf '%s' "$d" | tr '[:upper:]' '[:lower:]'
}

is_ghost_domain() {
	case "$1" in
	*2iw*|*yoltlbe*) return 0 ;;
	esac
	return 1
}

foreach_domain_text() {
	local text="$1" callback="$2" d
	text="$(printf '%s' "$text" | tr ',;\n\r\t' ' ')"
	for d in $text; do
		d="$(normalize_domain "$d")"
		[ -n "$d" ] || continue
		is_ghost_domain "$d" && continue
		case "$d" in
		*.*) "$callback" "$d" ;;
		esac
	done
}

append_domains_from_text() {
	local text="$1"
	foreach_domain_text "$text" append_domain_nftset
}

rule_is_enabled() {
	local section="$1" enabled
	enabled="$(uci -q get wdtt.${section}.enabled)"
	[ "$enabled" = "0" ] && return 1
	return 0
}

append_domain_nftset() {
	local domain="$1"
	domain="$(normalize_domain "$domain")"
	case "$domain" in
	*" "*|*/*/*|list\ domain*|option\ domain*) return 0 ;;
	*2iw.*|*yoltlbe*) log "WARN: skip ghost domain: ${domain}"; return 0 ;;
	esac
	case "$domain" in
	*.*) ;;
	*) log "WARN: skip invalid domain: ${domain}"; return 0 ;;
	esac
	[ -n "$domain" ] || return 0
	grep -qF "nftset=/${domain}/" "$DNSMASQ_SNIPPET" 2>/dev/null && return 0
	echo "nftset=/${domain}/${NFTSET_SUFFIX}${NFT_SET_ROUTE}" >> "$DNSMASQ_SNIPPET"
	log "nftset domain: ${domain}"
}

# Разбор UCI list: domain[0], domain[1] или 'a.com' 'b.com' в одной строке
_split_uci_values() {
	local raw="$1" callback="$2" part
	[ -n "$raw" ] || return 0
	raw="$(echo "$raw" | tr "'" " ")"
	for part in $raw; do
		[ -n "$part" ] && "$callback" "$part"
	done
}

uci_foreach_list() {
	local section="$1" option="$2" callback="$3" i=0 val found=0 line

	while val="$(uci -q get wdtt.${section}.${option}[$i] 2>/dev/null)" && [ -n "$val" ]; do
		"$callback" "$val"
		found=1
		i=$((i + 1))
	done

	if [ "$found" -eq 0 ]; then
		uci -q show "wdtt.${section}" 2>/dev/null | grep -E "^wdtt\.${section}\.${option}(\[|[=])" | while read -r line; do
			val="${line#*=}"
			val="${val#\'}"
			val="${val%\'}"
			[ -n "$val" ] && "$callback" "$val"
		done
		found=1
	fi

	if [ "$found" -eq 0 ]; then
		val="$(uci -q get wdtt.${section}.${option} 2>/dev/null)"
		_split_uci_values "$val" "$callback"
	fi
}

append_url_domains_raw() {
	local list_url="$1" domain tmp

	[ -n "$list_url" ] || return 0
	case "$list_url" in
		http://*|https://*) ;;
		*)
			log "skip invalid list_url: ${list_url}"
			return 0
			;;
	esac
	log "list_url fetch: ${list_url}"
	tmp="$(mktemp /tmp/wdtt-list.XXXXXX)"
	wget -qO "$tmp" "$list_url" 2>/dev/null || {
		rm -f "$tmp"
		return 0
	}
	while read -r domain; do
		domain="${domain%%#*}"
		domain="$(echo "$domain" | tr -d '[:space:]')"
		append_domain_nftset "$domain"
	done < "$tmp"
	rm -f "$tmp"
}

uci_line_value() {
	local line="$1" val
	val="${line#*\'}"
	if [ "$val" != "$line" ]; then
		val="${val%%\'*}"
		printf '%s' "$val"
		return 0
	fi
	val="${line#*\"}"
	val="${val%%\"*}"
	printf '%s' "$val"
}

# Надёжный разбор list domain (не uci_line_value — ломался на некоторых конфигах)
parse_list_domain_line() {
	local line="$1" val
	case "$line" in
		list\ domains\ *)
			val="${line#list domains}"
			;;
		list\ domain\ *)
			val="${line#list domain}"
			;;
		*) return 1 ;;
	esac
	val="$(trim_line "$val")"
	case "$val" in
		\'*\')
			val="${val#\'}"
			val="${val%\'}"
			;;
		\"*\")
			val="${val#\"}"
			val="${val%\"}"
			;;
	esac
	[ -n "$val" ] || return 1
	printf '%s' "$val"
}

# Legacy option domain — источник ghost 2iw.io / yoltlbe.com; удаляем из файла
remove_legacy_option_domains() {
	local tmp changed=0
	[ -r /etc/config/wdtt ] || return 0
	grep -qE '^[[:space:]]*option domain[[:space:]]' /etc/config/wdtt 2>/dev/null && changed=1
	grep -qE '^[[:space:]]*option domains[[:space:]]' /etc/config/wdtt 2>/dev/null && changed=1
	[ "$changed" -eq 1 ] || return 0
	tmp="$(mktemp /tmp/wdtt-cfg.XXXXXX)"
	grep -Ev '^[[:space:]]*option domain[[:space:]]' /etc/config/wdtt \
		| grep -Ev '^[[:space:]]*option domains[[:space:]]' > "$tmp" \
		|| { rm -f "$tmp"; return 0; }
	mv "$tmp" /etc/config/wdtt
	log "removed legacy option domain lines from /etc/config/wdtt"
}

uci_wdtt_parse_ok() {
	uci show wdtt 2>&1 | grep -qi 'parse error' && return 1
	return 0
}

trim_line() {
	local line="$1"
	line="${line#"${line%%[![:space:]]*}"}"
	line="${line%"${line##*[![:space:]]}"}"
	printf '%s' "$line"
}

# Синхронизация uci list domain ← /etc/config/wdtt (ghost indices: 2iw.io, yoltlbe.com)
_sync_one_rule_domains() {
	local section="$1" domains="$2" first d uci0

	first="${domains#"${domains%%[![:space:]]*}"}"
	first="${first%% *}"
	[ -n "$first" ] || return 0
	uci0="$(uci -q get wdtt.${section}.domain[0] 2>/dev/null)"
	[ "$uci0" = "$first" ] && return 0

	log "sync uci ${section}.domain from config file (was: ${uci0:-empty})"
	uci -q delete "wdtt.${section}.domain" 2>/dev/null
	for d in $domains; do
		[ -n "$d" ] && uci -q add_list "wdtt.${section}.domain=$d"
	done
	uci -q commit wdtt 2>/dev/null
}

sync_wdtt_domains_uci() {
	local line section="" domains="" count=0 in_rule=0 val

	[ -x /sbin/uci ] || return 0
	[ -r /etc/config/wdtt ] || return 0
	uci_wdtt_parse_ok || {
		log "WARN: uci wdtt parse error — skip uci sync (file-only dnsmasq)"
		return 0
	}

	while read -r line || [ -n "$line" ]; do
		line="$(trim_line "$line")"
		case "$line" in
			config\ rule\ *)
				[ -n "$section" ] && [ "$count" -gt 0 ] && _sync_one_rule_domains "$section" "$domains"
				section="${line#config rule }"
				section="${section#\'}"; section="${section%%\'*}"
				if [ "$section" = "${line#config rule }" ]; then
					section="${section#\"}"; section="${section%%\"*}"
				fi
				section="${section%% *}"
				domains=""; count=0; in_rule=1
				continue
				;;
			config\ *)
				[ -n "$section" ] && [ "$count" -gt 0 ] && _sync_one_rule_domains "$section" "$domains"
				section=""; domains=""; count=0; in_rule=0
				continue
				;;
		esac
		[ "$in_rule" -eq 1 ] || continue
		case "$line" in
			list\ domain|list\ domain\ *|list\ domains|list\ domains\ *)
				val="$(parse_list_domain_line "$line")" || continue
				domains="$domains $val"
				count=$((count + 1))
				;;
		esac
	done < /etc/config/wdtt
	[ -n "$section" ] && [ "$count" -gt 0 ] && _sync_one_rule_domains "$section" "$domains"
}

# domain_list (LuCI TextValue) + legacy list domain из /etc/config/wdtt
build_dnsmasq() {
	local line section="" type="route" enabled="1" in_rule=0 val n=0

	mkdir -p "$(dirname "$DNSMASQ_SNIPPET")"
	: > "$DNSMASQ_SNIPPET"

	[ -r /etc/config/wdtt ] || {
		log "ERROR: /etc/config/wdtt missing"
		return 1
	}

	remove_legacy_option_domains

	# НЕ вызываем sync_wdtt_domains_uci — uci commit при parse error ломает файл/ghost domains

	while read -r line || [ -n "$line" ]; do
		line="$(trim_line "$line")"
		case "$line" in
			""|\#*) continue ;;
			config\ rule\ *)
				section="${line#config rule }"
				section="${section#\'}"; section="${section%%\'*}"
				if [ "$section" = "${line#config rule }" ]; then
					section="${section#\"}"; section="${section%%\"*}"
				fi
				section="${section%% *}"
				type="route"
				enabled="1"
				in_rule=1
				log "rule ${section}: scan /etc/config/wdtt"
				continue
				;;
			config\ *)
				in_rule=0
				section=""
				continue
				;;
		esac

		[ "$in_rule" -eq 1 ] || continue

		case "$line" in
			option\ type\ *)
				type="$(uci_line_value "$line")"
				;;
			option\ enabled\ *)
				enabled="$(uci_line_value "$line")"
				;;
			option\ domain_list\ *)
				[ "$type" = "route" ] || continue
				[ "$enabled" = "0" ] && continue
				val="$(uci_line_value "$line")"
				append_domains_from_text "$val"
				;;
			list\ domain|list\ domain\ *|list\ domains|list\ domains\ *)
				[ "$type" = "route" ] || continue
				[ "$enabled" = "0" ] && continue
				val="$(parse_list_domain_line "$line")" || continue
				append_domain_nftset "$val"
				;;
			option\ domain|option\ domains*)
				log "WARN: ignoring legacy option domain (use domain_list in LuCI)"
				continue
				;;
			option\ list_url\ *)
				[ "$type" = "route" ] || continue
				[ "$enabled" = "0" ] && continue
				val="$(uci_line_value "$line")"
				append_url_domains_raw "$val"
				;;
		esac
	done < /etc/config/wdtt

	n=$(grep -c '^nftset=' "$DNSMASQ_SNIPPET" 2>/dev/null) || n=0
	log "dnsmasq: ${n} nftset domain(s) in $DNSMASQ_SNIPPET"
	if [ "$n" -eq 0 ]; then
		log "WARN: no domains in wdtt.conf"
	fi
	return 0
}

nft_add_one() {
	local setname="$1" elem="$2"
	[ -n "$elem" ] || return 0
	nft add element "$NFT_FAMILY" "$NFT_TABLE" "$setname" "{ $elem }" 2>/dev/null
}

nft_add_route_subnet() { nft_add_one "$NFT_SET_ROUTE" "$1"; }
nft_add_excl_subnet()  { nft_add_one "$NFT_SET_EXCL" "$1"; }
nft_add_src_ip()       { nft_add_one "$NFT_SET_SRC" "$1"; }
nft_add_excl_ip()      { nft_add_one "$NFT_SET_EXCL" "$1"; }

populate_nft_static() {
	uci_foreach_list globals routing_excluded_ip nft_add_excl_ip
	uci_foreach_list globals routing_excluded_ips nft_add_excl_ip
	config_foreach populate_rule_nft rule
}

populate_rule_nft() {
	local section="$1" type

	type="$(uci -q get wdtt.${section}.type)"
	rule_is_enabled "$section" || return 0

	case "$type" in
		route)
			uci_foreach_list "$section" subnet nft_add_route_subnet
			uci_foreach_list "$section" subnets nft_add_route_subnet
			uci_foreach_list "$section" source_ip nft_add_src_ip
			uci_foreach_list "$section" fully_routed_ip nft_add_src_ip
			;;
		exclusion)
			uci_foreach_list "$section" subnet nft_add_excl_subnet
			uci_foreach_list "$section" subnets nft_add_excl_subnet
			;;
	esac
}

write_nft_hook() {
	mkdir -p "$STATE_DIR"
	cat > "$NFT_HOOK" <<EOF
table ${NFT_FAMILY} ${NFT_TABLE} {
	set ${NFT_SET_ROUTE} {
		type ipv4_addr
		flags interval
	}

	set ${NFT_SET_EXCL} {
		type ipv4_addr
		flags interval
	}

	set ${NFT_SET_SRC} {
		type ipv4_addr
	}

	chain prerouting {
		type filter hook prerouting priority mangle; policy accept;
		ip saddr @${NFT_SET_EXCL} return
		ip daddr @${NFT_SET_EXCL} return
		ip saddr @${NFT_SET_SRC} meta mark set ${MARK}
		ip daddr @${NFT_SET_ROUTE} meta mark set ${MARK}
	}
}
EOF
}

cleanup_legacy_nft() {
	# Старые версии клали table в nftables.d — ломает fw4 reload
	rm -f "$NFT_HOOK_LEGACY"
}

cleanup_legacy_ipset() {
	iptables -t mangle -D PREROUTING -j WDTT 2>/dev/null
	iptables -t mangle -F WDTT 2>/dev/null
	iptables -t mangle -X WDTT 2>/dev/null
	ipset destroy wdtt_route 2>/dev/null
	ipset destroy wdtt_excl 2>/dev/null
	ipset destroy wdtt_src 2>/dev/null
}

setup_nft() {
	local err

	if ! command -v nft >/dev/null 2>&1; then
		log "ERROR: nft not found — apk add nftables kmod-nft-core"
		echo "ERROR: apk add nftables kmod-nft-core" >&2
		return 1
	fi

	modprobe nf_tables 2>/dev/null

	cleanup_legacy_nft
	cleanup_legacy_ipset
	write_nft_hook
	nft delete table "$NFT_FAMILY" "$NFT_TABLE" 2>/dev/null

	err="$(nft -f "$NFT_HOOK" 2>&1)" || {
		log "ERROR nft -f: $err"
		echo "ERROR nft -f: $err" >&2
		return 1
	}

	if ! nft list table "$NFT_FAMILY" "$NFT_TABLE" >/dev/null 2>&1; then
		log "ERROR: table inet wdtt not loaded after nft -f"
		echo "ERROR: table inet wdtt not loaded" >&2
		return 1
	fi

	log "nft table $NFT_TABLE loaded"
	return 0
}

teardown_nft() {
	rm -f "$NFT_HOOK"
	rm -f "$NFT_HOOK_LEGACY"
	nft delete table "$NFT_FAMILY" "$NFT_TABLE" 2>/dev/null
	cleanup_legacy_ipset
}

setup_policy_routing() {
	ip rule del fwmark "$MARK" table "$TABLE" 2>/dev/null
	ip route flush table "$TABLE" 2>/dev/null
	ip rule add fwmark "$MARK" table "$TABLE" priority 10050
	ip route add default dev "$IFACE" table "$TABLE" 2>/dev/null || {
		log "WARN: no route in table $TABLE for dev $IFACE (WireGuard up?)"
	}
}

reload_dnsmasq() {
	[ -f /etc/init.d/dnsmasq ] || return 0
	# reload не всегда подхватывает confdir/nftset — restart надёжнее
	/etc/init.d/dnsmasq restart 2>/dev/null || /etc/init.d/dnsmasq reload 2>/dev/null
	sleep 2
	pgrep -x dnsmasq >/dev/null 2>&1 || /etc/init.d/dnsmasq start 2>/dev/null
}

do_start() {
	local rc=0

	mkdir -p "$STATE_DIR" "$(dirname "$DNSMASQ_SNIPPET")"
	log "starting selective routing (nft) on $IFACE v3.7.3"

	[ -x /usr/libexec/wdtt/fix-config ] && /usr/libexec/wdtt/fix-config >/dev/null 2>&1 || true

	ensure_dnsmasq_confdir
	check_dnsmasq_nftset || return 1

	build_dnsmasq || rc=1

	setup_nft || rc=1
	if [ "$rc" -eq 0 ]; then
		config_load wdtt
		populate_nft_static
		setup_policy_routing
		reload_dnsmasq
		warmup_nftset_domains
		echo "selective" > "$STATE_DIR/routing.mode"
		log "selective routing active"
	else
		rm -f "$STATE_DIR/routing.mode"
		log "selective routing FAILED (see errors above)"
	fi

	return "$rc"
}

do_stop() {
	log "stopping selective routing"
	teardown_nft
	ip rule del fwmark "$MARK" table "$TABLE" 2>/dev/null
	ip route flush table "$TABLE" 2>/dev/null
	rm -f "$DNSMASQ_SNIPPET"
	reload_dnsmasq
	rm -f "$STATE_DIR/routing.mode"
	log "selective routing stopped"
}

do_reload() {
	do_stop
	do_start
}

show_rule_status() {
	local section="$1" type enabled
	type="$(uci -q get wdtt.${section}.type)"
	enabled="$(uci -q get wdtt.${section}.enabled)"
	[ -z "$enabled" ] && enabled="(unset→on)"
	echo "  rule ${section}: type=${type:-?} enabled=${enabled}"
}

do_status() {
	local mode n
	mode="$(uci -q get wdtt.globals.routing_mode)"
	echo "routing_mode=${mode:-?}"
	echo "routing_script=$(grep -m1 'WDTT_ROUTING_VERSION=' /usr/libexec/wdtt/routing 2>/dev/null || echo unknown)"
	echo "state_file=$(cat "$STATE_DIR/routing.mode" 2>/dev/null || echo missing)"
	echo "dnsmasq_confdir=$(uci -q get dhcp.@dnsmasq[0].confdir 2>/dev/null)"
	echo "nft=$(command -v nft || echo missing)"
	echo "--- uci rules ---"
	config_load wdtt
	config_foreach show_rule_status rule
	echo "--- legacy option domain (must be empty) ---"
	grep -E '^[[:space:]]*option domains?[[:space:]]' /etc/config/wdtt 2>/dev/null \
		|| echo "(none — OK)"
	echo "domain_list=$(uci -q get wdtt.route1.domain_list 2>/dev/null \
		|| uci -q get wdtt.youtube.domain_list 2>/dev/null || echo -)"
	echo "file domains=$(grep -E 'domain_list|list domain' /etc/config/wdtt 2>/dev/null | head -5)"
	echo "--- /etc/config/wdtt (rules) ---"
	grep -E "^config rule|domain|list_url" /etc/config/wdtt 2>/dev/null | head -20
	echo "--- $DNSMASQ_SNIPPET ---"
	if [ -f "$DNSMASQ_SNIPPET" ] && [ -s "$DNSMASQ_SNIPPET" ]; then
		cat "$DNSMASQ_SNIPPET"
		n=$(grep -c '^nftset=' "$DNSMASQ_SNIPPET" 2>/dev/null) || n=0
		echo "($n nftset entries)"
	else
		echo "(empty)"
	fi
	echo "--- nft table ---"
	nft list table "$NFT_FAMILY" "$NFT_TABLE" 2>/dev/null | head -35 \
		|| echo "(missing — run: routing reload wg-wdtt; check: logread | grep wdtt-routing)"
	n=$(nft list set "$NFT_FAMILY" "$NFT_TABLE" "$NFT_SET_ROUTE" 2>/dev/null | grep -cE '^\s+[0-9]+\.[0-9]+') || n=0
	echo "wdtt_route IPs: ${n} (0 = warmup failed or no DNS yet)"
	echo "--- ip route table $TABLE ---"
	ip route show table "$TABLE" 2>/dev/null || echo "(empty — routing reload после connected)"
	echo "--- firewall lan→wdtt ---"
	uci -q get firewall.wdtt_lan_fwd.src 2>/dev/null && \
		echo "forwarding: $(uci -q get firewall.wdtt_lan_fwd.src) → $(uci -q get firewall.wdtt_lan_fwd.dest)" \
		|| echo "(missing — sh /etc/uci-defaults/99-wdtt)"
}

EXIT_RC=0

case "$1" in
	start)
		routing_mode="$(uci -q get wdtt.globals.routing_mode)"
		[ "$routing_mode" = "full" ] && exit 0
		[ "$(uci -q get wdtt.globals.full_tunnel)" = "1" ] && exit 0
		do_start
		EXIT_RC=$?
		;;
	stop)
		do_stop
		;;
	reload)
		do_reload
		EXIT_RC=$?
		;;
	status)
		do_status
		;;
	*)
		echo "Usage: $0 {start|stop|reload|status} [iface]" >&2
		exit 1
		;;
esac

exit "$EXIT_RC"
