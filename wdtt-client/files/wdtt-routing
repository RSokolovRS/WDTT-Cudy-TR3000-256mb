#!/bin/sh
# WDTT selective routing — OpenWrt 25 / fw4
# dnsmasq nftset → nft sets → fwmark → ip rule table 100 → wg-wdtt

. /lib/functions.sh

MARK=0x777474
TABLE=100
IFACE="${2:-wg-wdtt}"

NFT_TABLE=wdtt
NFT_SET_ROUTE=wdtt_route
NFT_SET_EXCL=wdtt_excl
NFT_SET_SRC=wdtt_src
NFT_FAMILY=inet

DNSMASQ_SNIPPET=/tmp/dnsmasq.d/wdtt.conf
NFT_HOOK=/etc/nftables.d/99-wdtt.nft
STATE_DIR=/var/run/wdtt

log() { logger -t wdtt-routing "$*"; }

# dnsmasq: nftset=/domain/4#inet#wdtt#wdtt_route
NFTSET_SUFFIX="4#${NFT_FAMILY}#${NFT_TABLE}#"

normalize_domain() {
	local d="$1"
	d="${d#https://}"
	d="${d#http://}"
	d="${d%%/*}"
	d="${d%/}"
	printf '%s' "$d" | tr '[:upper:]' '[:lower:]'
}

uci_list() {
	local section="$1" option="$2"
	uci -q show "wdtt.${section}.${option}" 2>/dev/null | \
		sed -n "s/^wdtt\.${section}\.${option}\(=\|\[\d\+\]=\)//p" | \
		sed "s/^'//;s/'$//"
}

collect_domains() {
	local section="$1" type="$2" list_url domain

	[ "$(uci -q get wdtt.${section}.enabled)" = "0" ] && return 0
	[ "$(uci -q get wdtt.${section}.type)" != "$type" ] && return 0

	list_url="$(uci -q get wdtt.${section}.list_url)"
	if [ -n "$list_url" ]; then
		wget -qO- "$list_url" 2>/dev/null | while read -r domain; do
			domain="${domain%%#*}"
			domain="$(echo "$domain" | tr -d '[:space:]')"
			domain="$(normalize_domain "$domain")"
			[ -n "$domain" ] && echo "$domain"
		done
	fi

	uci_list "$section" domain
	uci_list "$section" domains
}

collect_subnets() {
	local section="$1" type="$2"
	[ "$(uci -q get wdtt.${section}.enabled)" = "0" ] && return 0
	[ "$(uci -q get wdtt.${section}.type)" != "$type" ] && return 0
	uci_list "$section" subnet
	uci_list "$section" subnets
}

collect_source_ips() {
	local section="$1"
	[ "$(uci -q get wdtt.${section}.enabled)" = "0" ] && return 0
	[ "$(uci -q get wdtt.${section}.type)" != "route" ] && return 0
	uci_list "$section" source_ip
	uci_list "$section" fully_routed_ip
}

build_dnsmasq() {
	local n=0

	mkdir -p "$(dirname "$DNSMASQ_SNIPPET")"
	: > "$DNSMASQ_SNIPPET"

	config_load wdtt
	config_foreach build_rule_dnsmasq rule

	n="$(grep -c '^nftset=' "$DNSMASQ_SNIPPET" 2>/dev/null || echo 0)"
	log "dnsmasq: ${n} nftset domain(s) in $DNSMASQ_SNIPPET"
}

build_rule_dnsmasq() {
	local section="$1" type domain

	type="$(uci -q get wdtt.${section}.type)"
	[ "$type" = "route" ] || return 0
	[ "$(uci -q get wdtt.${section}.enabled)" = "0" ] && return 0

	collect_domains "$section" route | while read -r domain; do
		domain="$(normalize_domain "$domain")"
		[ -n "$domain" ] && echo "nftset=/${domain}/${NFTSET_SUFFIX}${NFT_SET_ROUTE}" >> "$DNSMASQ_SNIPPET"
	done
}

nft_add_one() {
	local setname="$1" elem="$2"
	[ -n "$elem" ] || return 0
	nft add element "$NFT_FAMILY" "$NFT_TABLE" "$setname" "{ $elem }" 2>/dev/null
}

populate_nft_static() {
	local section type subnet ip

	uci_list globals routing_excluded_ip | while read -r ip; do
		nft_add_one "$NFT_SET_EXCL" "$ip"
	done
	uci_list globals routing_excluded_ips | while read -r ip; do
		nft_add_one "$NFT_SET_EXCL" "$ip"
	done

	config_load wdtt
	config_foreach populate_rule_nft rule
}

populate_rule_nft() {
	local section="$1" type

	type="$(uci -q get wdtt.${section}.type)"
	[ "$(uci -q get wdtt.${section}.enabled)" = "0" ] && return 0

	case "$type" in
		route)
			collect_subnets "$section" route | while read -r subnet; do
				nft_add_one "$NFT_SET_ROUTE" "$subnet"
			done
			collect_source_ips "$section" | while read -r ip; do
				nft_add_one "$NFT_SET_SRC" "$ip"
			done
			;;
		exclusion)
			collect_subnets "$section" exclusion | while read -r subnet; do
				nft_add_one "$NFT_SET_EXCL" "$subnet"
			done
			;;
	esac
}

write_nft_hook() {
	mkdir -p /etc/nftables.d
	cat > "$NFT_HOOK" <<EOF
# WDTT selective routing (managed by /usr/libexec/wdtt/routing)
table ${NFT_FAMILY} ${NFT_TABLE} {
	set ${NFT_SET_ROUTE} {
		type ipv4_addr
		flags interval
		auto-merge
	}

	set ${NFT_SET_EXCL} {
		type ipv4_addr
		flags interval
		auto-merge
	}

	set ${NFT_SET_SRC} {
		type ipv4_addr
	}

	chain prerouting {
		type filter hook prerouting priority mangle; policy accept;

		ip saddr @${NFT_SET_EXCL} return
		ip daddr @${NFT_SET_EXCL} return
		ip saddr @${NFT_SET_SRC} meta mark set ${MARK}
		ip daddr @${NFT_SET_ROUTE} meta mark set ${MARK}
	}
}
EOF
}

cleanup_legacy_ipset() {
	# Старые версии скрипта
	iptables -t mangle -D PREROUTING -j WDTT 2>/dev/null
	iptables -t mangle -F WDTT 2>/dev/null
	iptables -t mangle -X WDTT 2>/dev/null
	ipset destroy wdtt_route 2>/dev/null
	ipset destroy wdtt_excl 2>/dev/null
	ipset destroy wdtt_src 2>/dev/null
}

setup_nft() {
	if ! command -v nft >/dev/null 2>&1; then
		log "nft missing — apk add nftables kmod-nft-core"
		return 1
	fi

	cleanup_legacy_ipset
	write_nft_hook

	nft delete table "$NFT_FAMILY" "$NFT_TABLE" 2>/dev/null

	if [ -x /sbin/fw4 ]; then
		fw4 reload 2>/dev/null || nft -f "$NFT_HOOK"
	else
		nft -f "$NFT_HOOK" 2>/dev/null
	fi

	if ! nft list table "$NFT_FAMILY" "$NFT_TABLE" >/dev/null 2>&1; then
		log "ERROR: nft table $NFT_TABLE not loaded"
		return 1
	fi

	log "nft table $NFT_TABLE active (fw4)"
	return 0
}

teardown_nft() {
	rm -f "$NFT_HOOK"
	nft delete table "$NFT_FAMILY" "$NFT_TABLE" 2>/dev/null
	[ -x /sbin/fw4 ] && fw4 reload 2>/dev/null
	cleanup_legacy_ipset
}

setup_policy_routing() {
	ip rule del fwmark "$MARK" table "$TABLE" 2>/dev/null
	ip route flush table "$TABLE" 2>/dev/null

	ip rule add fwmark "$MARK" table "$TABLE" priority 10050
	ip route add default dev "$IFACE" table "$TABLE" 2>/dev/null
}

reload_dnsmasq() {
	[ -f /etc/init.d/dnsmasq ] && /etc/init.d/dnsmasq restart 2>/dev/null
}

do_start() {
	mkdir -p "$STATE_DIR" "$(dirname "$DNSMASQ_SNIPPET")"
	log "starting selective routing (nft) on $IFACE"

	setup_nft || {
		log "ERROR: nft setup failed"
		return 1
	}

	build_dnsmasq
	populate_nft_static
	setup_policy_routing
	reload_dnsmasq

	echo "selective" > "$STATE_DIR/routing.mode"
	log "selective routing active (nft+nftset)"
}

do_stop() {
	log "stopping selective routing"

	teardown_nft
	ip rule del fwmark "$MARK" table "$TABLE" 2>/dev/null
	ip route flush table "$TABLE" 2>/dev/null
	rm -f "$DNSMASQ_SNIPPET"
	reload_dnsmasq
	rm -f "$STATE_DIR/routing.mode"
	log "selective routing stopped"
}

do_reload() {
	do_stop
	do_start
}

do_status() {
	local mode n
	mode="$(uci -q get wdtt.globals.routing_mode)"
	echo "routing_mode=${mode:-?}"
	echo "backend=nft+nftset"
	echo "state_file=$(cat "$STATE_DIR/routing.mode" 2>/dev/null || echo missing)"
	echo "dnsmasq_confdir=$(uci -q get dhcp.@dnsmasq[0].confdir 2>/dev/null)"
	echo "--- uci rules ---"
	uci show wdtt 2>/dev/null | grep -E 'rule|domain|enabled|type' || true
	echo "--- $DNSMASQ_SNIPPET ---"
	if [ -f "$DNSMASQ_SNIPPET" ] && [ -s "$DNSMASQ_SNIPPET" ]; then
		cat "$DNSMASQ_SNIPPET"
		n="$(grep -c '^nftset=' "$DNSMASQ_SNIPPET")"
		echo "($n nftset entries)"
	else
		echo "(empty — включите rule route + domain, затем: routing reload wg-wdtt)"
	fi
	echo "--- nft set $NFT_SET_ROUTE ---"
	nft list set "$NFT_FAMILY" "$NFT_TABLE" "$NFT_SET_ROUTE" 2>/dev/null | head -20 \
		|| echo "(missing — routing start failed?)"
	echo "--- nft chain prerouting ---"
	nft list chain "$NFT_FAMILY" "$NFT_TABLE" prerouting 2>/dev/null | head -10 \
		|| echo "(missing)"
	echo "--- ip rule ---"
	ip rule | grep -F "$MARK" || echo "(no policy rule)"
}

case "$1" in
	start)
		routing_mode="$(uci -q get wdtt.globals.routing_mode)"
		[ "$routing_mode" = "full" ] && exit 0
		[ "$(uci -q get wdtt.globals.full_tunnel)" = "1" ] && exit 0
		do_start
		;;
	stop)   do_stop ;;
	reload) do_reload ;;
	status) do_status ;;
	*)      echo "Usage: $0 {start|stop|reload|status} [iface]" >&2; exit 1 ;;
esac

exit 0
