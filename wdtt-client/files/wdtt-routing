#!/bin/sh
# WDTT selective routing — policy routing как в Podkop
# dnsmasq ipset → iptables/nft mark → ip rule table 100 → wg-wdtt

. /lib/functions.sh

MARK=0x777474
TABLE=100
IFACE="${2:-wg-wdtt}"

IPSET_ROUTE=wdtt_route
IPSET_EXCL=wdtt_excl
IPSET_SRC=wdtt_src
IPT_CHAIN=WDTT

DNSMASQ_SNIPPET=/tmp/dnsmasq.d/wdtt.conf
STATE_DIR=/var/run/wdtt

log() { logger -t wdtt-routing "$*"; }

# https://2ip.io/ → 2ip.io
normalize_domain() {
	local d="$1"
	d="${d#https://}"
	d="${d#http://}"
	d="${d%%/*}"
	d="${d%/}"
	printf '%s' "$d" | tr '[:upper:]' '[:lower:]'
}

# UCI list: domain='x' и domain[0]='x'
uci_list() {
	local section="$1" option="$2"
	uci -q show "wdtt.${section}.${option}" 2>/dev/null | \
		sed -n "s/^wdtt\.${section}\.${option}\(=\|\[\d\+\]=\)//p" | \
		sed "s/^'//;s/'$//"
}

ipset_create() {
	local name="$1"
	ipset destroy "$name" 2>/dev/null
	ipset create "$name" hash:net family inet hashsize 4096 maxelem 65536 2>/dev/null || \
		ipset flush "$name" 2>/dev/null
}

collect_domains() {
	local section="$1" type="$2" list_url domain

	[ "$(uci -q get wdtt.${section}.enabled)" = "0" ] && return 0
	[ "$(uci -q get wdtt.${section}.type)" != "$type" ] && return 0

	list_url="$(uci -q get wdtt.${section}.list_url)"
	if [ -n "$list_url" ]; then
		wget -qO- "$list_url" 2>/dev/null | while read -r domain; do
			domain="${domain%%#*}"
			domain="$(echo "$domain" | tr -d '[:space:]')"
			domain="$(normalize_domain "$domain")"
			[ -n "$domain" ] && echo "$domain"
		done
	fi

	uci_list "$section" domain
	uci_list "$section" domains
}

collect_subnets() {
	local section="$1" type="$2"
	[ "$(uci -q get wdtt.${section}.enabled)" = "0" ] && return 0
	[ "$(uci -q get wdtt.${section}.type)" != "$type" ] && return 0
	uci_list "$section" subnet
	uci_list "$section" subnets
}

collect_source_ips() {
	local section="$1"
	[ "$(uci -q get wdtt.${section}.enabled)" = "0" ] && return 0
	[ "$(uci -q get wdtt.${section}.type)" != "route" ] && return 0
	uci_list "$section" source_ip
	uci_list "$section" fully_routed_ip
}

build_dnsmasq() {
	local section domain n=0

	mkdir -p "$(dirname "$DNSMASQ_SNIPPET")"
	: > "$DNSMASQ_SNIPPET"

	config_load wdtt
	config_foreach build_rule_dnsmasq rule

	n="$(grep -c '^ipset=' "$DNSMASQ_SNIPPET" 2>/dev/null || echo 0)"
	log "dnsmasq: ${n} domain(s) in $DNSMASQ_SNIPPET"
}

build_rule_dnsmasq() {
	local section="$1" type domain

	type="$(uci -q get wdtt.${section}.type)"
	[ "$type" = "route" ] || return 0
	[ "$(uci -q get wdtt.${section}.enabled)" = "0" ] && return 0

	collect_domains "$section" route | while read -r domain; do
		domain="$(normalize_domain "$domain")"
		[ -n "$domain" ] && echo "ipset=/${domain}/${IPSET_ROUTE}" >> "$DNSMASQ_SNIPPET"
	done
}

populate_ipsets() {
	ipset_create "$IPSET_ROUTE"
	ipset_create "$IPSET_EXCL"
	ipset_create "$IPSET_SRC"

	uci_list globals routing_excluded_ip | while read -r ip; do
		[ -n "$ip" ] && ipset add "$IPSET_EXCL" "$ip" 2>/dev/null
	done
	uci_list globals routing_excluded_ips | while read -r ip; do
		[ -n "$ip" ] && ipset add "$IPSET_EXCL" "$ip" 2>/dev/null
	done

	config_load wdtt
	config_foreach populate_rule_ipsets rule
}

populate_rule_ipsets() {
	local section="$1" type

	type="$(uci -q get wdtt.${section}.type)"
	[ "$(uci -q get wdtt.${section}.enabled)" = "0" ] && return 0

	case "$type" in
		route)
			collect_subnets "$section" route | while read -r subnet; do
				[ -n "$subnet" ] && ipset add "$IPSET_ROUTE" "$subnet" 2>/dev/null
			done
			collect_source_ips "$section" | while read -r ip; do
				[ -n "$ip" ] && ipset add "$IPSET_SRC" "$ip" 2>/dev/null
			done
			;;
		exclusion)
			collect_subnets "$section" exclusion | while read -r subnet; do
				[ -n "$subnet" ] && ipset add "$IPSET_EXCL" "$subnet" 2>/dev/null
			done
			;;
	esac
}

# ipset создаётся через `ipset`, nft @name — это nft-set (другой тип). Используем iptables mangle.
setup_mark_rules() {
	if ! command -v iptables >/dev/null 2>&1; then
		log "iptables missing — apk add iptables iptables-mod-ipset"
		return 1
	fi

	iptables -t mangle -N "$IPT_CHAIN" 2>/dev/null || iptables -t mangle -F "$IPT_CHAIN"
	iptables -t mangle -D PREROUTING -j "$IPT_CHAIN" 2>/dev/null

	iptables -t mangle -A "$IPT_CHAIN" -m set --match-set "$IPSET_EXCL" src -j RETURN 2>/dev/null
	iptables -t mangle -A "$IPT_CHAIN" -m set --match-set "$IPSET_EXCL" dst -j RETURN 2>/dev/null
	iptables -t mangle -A "$IPT_CHAIN" -m set --match-set "$IPSET_SRC" src -j MARK --set-mark "$MARK" 2>/dev/null
	iptables -t mangle -A "$IPT_CHAIN" -m set --match-set "$IPSET_ROUTE" dst -j MARK --set-mark "$MARK" 2>/dev/null
	iptables -t mangle -I PREROUTING 1 -j "$IPT_CHAIN" 2>/dev/null

	log "iptables mangle chain $IPT_CHAIN active"
	return 0
}

teardown_mark_rules() {
	iptables -t mangle -D PREROUTING -j "$IPT_CHAIN" 2>/dev/null
	iptables -t mangle -F "$IPT_CHAIN" 2>/dev/null
	iptables -t mangle -X "$IPT_CHAIN" 2>/dev/null
}

setup_policy_routing() {
	ip rule del fwmark "$MARK" table "$TABLE" 2>/dev/null
	ip route flush table "$TABLE" 2>/dev/null

	ip rule add fwmark "$MARK" table "$TABLE" priority 10050
	ip route add default dev "$IFACE" table "$TABLE" 2>/dev/null
}

reload_dnsmasq() {
	[ -f /etc/init.d/dnsmasq ] && /etc/init.d/dnsmasq restart 2>/dev/null
}

do_start() {
	mkdir -p "$STATE_DIR" "$(dirname "$DNSMASQ_SNIPPET")"
	log "starting selective routing on $IFACE"

	build_dnsmasq
	populate_ipsets
	setup_mark_rules || log "WARN: mark rules failed (install iptables-mod-ipset kmod-ipt-ipset)"
	setup_policy_routing
	reload_dnsmasq

	echo "selective" > "$STATE_DIR/routing.mode"
	log "selective routing active"
}

do_stop() {
	log "stopping selective routing"

	teardown_mark_rules
	ip rule del fwmark "$MARK" table "$TABLE" 2>/dev/null
	ip route flush table "$TABLE" 2>/dev/null

	rm -f "$DNSMASQ_SNIPPET"

	ipset destroy "$IPSET_ROUTE" 2>/dev/null
	ipset destroy "$IPSET_EXCL" 2>/dev/null
	ipset destroy "$IPSET_SRC" 2>/dev/null

	reload_dnsmasq
	rm -f "$STATE_DIR/routing.mode"
	log "selective routing stopped"
}

do_reload() {
	do_stop
	do_start
}

do_status() {
	local mode n
	mode="$(uci -q get wdtt.globals.routing_mode)"
	echo "routing_mode=${mode:-?}"
	echo "state_file=$(cat "$STATE_DIR/routing.mode" 2>/dev/null || echo missing)"
	echo "dnsmasq_confdir=$(uci -q get dhcp.@dnsmasq[0].confdir 2>/dev/null)"
	echo "--- uci rules ---"
	uci show wdtt 2>/dev/null | grep -E 'rule|domain|enabled|type' || true
	echo "--- $DNSMASQ_SNIPPET ---"
	if [ -f "$DNSMASQ_SNIPPET" ] && [ -s "$DNSMASQ_SNIPPET" ]; then
		cat "$DNSMASQ_SNIPPET"
		n="$(grep -c '^ipset=' "$DNSMASQ_SNIPPET")"
		echo "($n entries)"
	else
		echo "(empty)"
	fi
	echo "--- ipset $IPSET_ROUTE ---"
	ipset list "$IPSET_ROUTE" 2>/dev/null | head -25 || echo "(missing — apk add ipset)"
	echo "--- iptables $IPT_CHAIN ---"
	iptables -t mangle -L "$IPT_CHAIN" -n 2>/dev/null | head -10 || echo "(missing — apk add iptables iptables-mod-ipset)"
	echo "--- ip rule ---"
	ip rule | grep -F "$MARK" || echo "(no policy rule)"
}

case "$1" in
	start)
		routing_mode="$(uci -q get wdtt.globals.routing_mode)"
		[ "$routing_mode" = "full" ] && exit 0
		[ "$(uci -q get wdtt.globals.full_tunnel)" = "1" ] && exit 0
		do_start
		;;
	stop)   do_stop ;;
	reload) do_reload ;;
	status) do_status ;;
	*)      echo "Usage: $0 {start|stop|reload|status} [iface]" >&2; exit 1 ;;
esac

exit 0
