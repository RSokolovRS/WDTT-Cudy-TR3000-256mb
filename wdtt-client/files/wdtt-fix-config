#!/bin/sh
# Нормализация /etc/config/wdtt: ghost option domain, multiline hashes, broken uci list domain

WDtt_CFG=/etc/config/wdtt

log() { logger -t wdtt-fix-config "$*"; }

[ -f "$WDtt_CFG" ] || { log "ERROR: $WDtt_CFG missing"; exit 1; }

trim_line() {
	local line="$1"
	line="${line#"${line%%[![:space:]]*}"}"
	line="${line%"${line##*[![:space:]]}"}"
	printf '%s' "$line"
}

parse_list_domain_line() {
	local line="$1" val
	case "$line" in
		list\ domains\ *) val="${line#list domains}" ;;
		list\ domain\ *) val="${line#list domain}" ;;
		*) return 1 ;;
	esac
	val="$(trim_line "$val")"
	case "$val" in
		\'*\') val="${val#\'}"; val="${val%\'}" ;;
		\"*\") val="${val#\"}"; val="${val%\"}" ;;
	esac
	[ -n "$val" ] || return 1
	printf '%s' "$val"
}

uci_line_value() {
	local line="$1" val
	val="${line#*\'}"
	if [ "$val" != "$line" ]; then
		val="${val%%\'*}"
		printf '%s' "$val"
		return 0
	fi
	val="${line#*\"}"
	val="${val%%\"*}"
	printf '%s' "$val"
}

normalize_domain() {
	local d="$1"
	d="${d#https://}"
	d="${d#http://}"
	d="${d%%/*}"
	d="${d%/}"
	printf '%s' "$d" | tr '[:upper:]' '[:lower:]'
}

is_ghost_domain() {
	case "$1" in
	*2iw*|*yoltlbe*) return 0 ;;
	esac
	return 1
}

# Собрать уникальный список доменов (через запятую) из текста / legacy list
normalize_domain_list_text() {
	local text="$1" d out="" part=""
	text="$(printf '%s' "$text" | tr ',;\n\r\t' ' ')"
	for d in $text; do
		d="$(normalize_domain "$d")"
		[ -n "$d" ] || continue
		is_ghost_domain "$d" && continue
		case "$d" in *.*) ;; *) continue ;; esac
		case " $out " in
		*" $d "*) continue ;;
		esac
		[ -n "$out" ] && out="${out},${d}" || out="$d"
	done
	printf '%s' "$out"
}

merge_domain_list_text() {
	local a="$1" b="$2"
	[ -n "$a" ] && [ -n "$b" ] && printf '%s' "$(normalize_domain_list_text "$a,$b")"
	[ -n "$a" ] && printf '%s' "$(normalize_domain_list_text "$a")"
	[ -n "$b" ] && printf '%s' "$(normalize_domain_list_text "$b")"
	printf '%s' ""
}

flush_rule_domain_list() {
	local section="$1" merged="$2" tmp="$3"
	merged="$(normalize_domain_list_text "$merged")"
	[ -n "$merged" ] || return 0
	echo "	option domain_list '${merged}'" >> "$tmp"
	if [ -x /sbin/uci ]; then
		uci -q set "wdtt.${section}.domain_list=${merged}" 2>/dev/null
		while uci -q delete "wdtt.${section}.domain" 2>/dev/null; do :; done
	fi
	log "rule ${section}: domain_list=${merged}"
}

# LuCI DynamicList (list domain) на OpenWrt 25 даёт ghost 2iw.rl — мигрируем в option domain_list
migrate_rules_to_domain_list() {
	local tmp line trimmed section="" in_rule=0 val merged="" changed=0

	grep -qE 'list domain|option domain_list|option domain[^_]' "$WDtt_CFG" 2>/dev/null || return 0

	tmp="$(mktemp /tmp/wdtt-fix.XXXXXX)"
	while read -r line || [ -n "$line" ]; do
		trimmed="$(trim_line "$line")"
		case "$trimmed" in
			config\ rule\ *)
				[ -n "$section" ] && flush_rule_domain_list "$section" "$merged" "$tmp"
				section="${trimmed#config rule }"
				section="${section#\'}"; section="${section%%\'*}"
				section="${section#\"}"; section="${section%%\"*}"
				section="${section%% *}"
				in_rule=1
				merged=""
				changed=1
				echo "$line" >> "$tmp"
				;;
			config\ *)
				[ -n "$section" ] && flush_rule_domain_list "$section" "$merged" "$tmp"
				section=""
				in_rule=0
				merged=""
				echo "$line" >> "$tmp"
				;;
			*)
				if [ "$in_rule" -eq 1 ]; then
					case "$trimmed" in
						list\ domain|list\ domain\ *|list\ domains|list\ domains\ *)
							val="$(parse_list_domain_line "$trimmed")" || continue
							merged="$(merge_domain_list_text "$merged" "$val")"
							changed=1
							continue
							;;
						option\ domain_list\ *)
							val="$(uci_line_value "$trimmed")"
							merged="$(merge_domain_list_text "$merged" "$val")"
							changed=1
							continue
							;;
						option\ domain|option\ domains*)
							changed=1
							continue
							;;
					esac
				fi
				echo "$line" >> "$tmp"
				;;
		esac
	done < "$WDtt_CFG"

	[ -n "$section" ] && flush_rule_domain_list "$section" "$merged" "$tmp"

	if [ "$changed" -eq 1 ]; then
		mv "$tmp" "$WDtt_CFG"
		[ -x /sbin/uci ] && uci -q commit wdtt 2>/dev/null
		log "migrated list domain → domain_list (LuCI-safe)"
	else
		rm -f "$tmp"
	fi
}

fix_option_domain_lines() {
	local tmp changed=0

	grep -qE '^[[:space:]]*option domain[[:space:]]' "$WDtt_CFG" 2>/dev/null && changed=1
	grep -qE '^[[:space:]]*option domains[[:space:]]' "$WDtt_CFG" 2>/dev/null && changed=1
	[ "$changed" -eq 1 ] || return 0

	tmp="$(mktemp /tmp/wdtt-fix.XXXXXX)"
	grep -Ev '^[[:space:]]*option domain[[:space:]]' "$WDtt_CFG" \
		| grep -Ev '^[[:space:]]*option domains[[:space:]]' > "$tmp" \
		|| { rm -f "$tmp"; return 1; }
	mv "$tmp" "$WDtt_CFG"
	log "removed legacy option domain lines"
}

# list domain в globals — LuCI/uci ghost (2iw.io); routing читает только config rule
fix_globals_list_domains() {
	local tmp line section="" in_globals=0 changed=0

	tmp="$(mktemp /tmp/wdtt-fix.XXXXXX)"
	while read -r line || [ -n "$line" ]; do
		case "$line" in
			config\ globals\ *)
				section="globals"
				in_globals=1
				echo "$line" >> "$tmp"
				continue
				;;
			config\ *)
				in_globals=0
				section=""
				echo "$line" >> "$tmp"
				continue
				;;
		esac
		if [ "$in_globals" -eq 1 ]; then
			case "$line" in
				*list\ domain*|*list\ domains*)
					changed=1
					continue
					;;
			esac
		fi
		echo "$line" >> "$tmp"
	done < "$WDtt_CFG"

	if [ "$changed" -eq 1 ]; then
		mv "$tmp" "$WDtt_CFG"
		log "removed list domain from globals section"
	else
		rm -f "$tmp"
	fi

	[ -x /sbin/uci ] || return 0
	uci -q delete wdtt.globals.domain 2>/dev/null
	uci -q delete wdtt.globals.domains 2>/dev/null
}

# LuCI/UCI ghost: 2ip.ru→2iw.rl, youtube.com→yoltlbe.com — удаляем из файла напрямую
purge_ghost_list_domains_from_file() {
	local tmp line trimmed val changed=0

	grep -qE '(2iw\.|yoltlbe)' "$WDtt_CFG" 2>/dev/null || return 0

	tmp="$(mktemp /tmp/wdtt-fix.XXXXXX)"
	while read -r line || [ -n "$line" ]; do
		trimmed="$(trim_line "$line")"
		case "$trimmed" in
			list\ domain|list\ domain\ *|list\ domains|list\ domains\ *)
				val="$(parse_list_domain_line "$trimmed")" || {
					echo "$line" >> "$tmp"
					continue
				}
				case "$val" in
				*2iw*|*yoltlbe*)
					changed=1
					log "remove ghost list domain from file: ${val}"
					continue
					;;
				esac
				;;
			option\ domain_list\ *)
				val="$(uci_line_value "$trimmed")"
				val="$(normalize_domain_list_text "$val")"
				if [ -n "$val" ]; then
					echo "	option domain_list '${val}'" >> "$tmp"
				else
					changed=1
				fi
				continue
				;;
		esac
		echo "$line" >> "$tmp"
	done < "$WDtt_CFG"

	if [ "$changed" -eq 1 ]; then
		mv "$tmp" "$WDtt_CFG"
		log "purged ghost domains from ${WDtt_CFG}"
	else
		rm -f "$tmp"
	fi
}

sanitize_rule_domain_list_uci() {
	local section="$1" val
	[ -n "$section" ] || return 0
	[ -x /sbin/uci ] || return 0
	val="$(uci -q get "wdtt.${section}.domain_list" 2>/dev/null)" || return 0
	val="$(normalize_domain_list_text "$val")"
	if [ -n "$val" ]; then
		uci -q set "wdtt.${section}.domain_list=${val}" 2>/dev/null
	else
		uci -q delete "wdtt.${section}.domain_list" 2>/dev/null
	fi
	while uci -q delete "wdtt.${section}.domain" 2>/dev/null; do :; done
}

# LuCI TextValue с переносами ломает UCI: option domain_list 'youtube.com  (без ')
fix_multiline_domain_list() {
	local tmp line in_domain=0 payload="" prefix=""

	grep -q 'option domain_list' "$WDtt_CFG" 2>/dev/null || return 0
	if grep -E "^[[:space:]]*option domain_list '[^']+'[[:space:]]*$" "$WDtt_CFG" >/dev/null 2>&1; then
		return 0
	fi

	tmp="$(mktemp /tmp/wdtt-fix.XXXXXX)"
	while read -r line || [ -n "$line" ]; do
		case "$line" in
			*"option domain_list"*)
				in_domain=1
				prefix="${line%%option domain_list*}"
				line="${line#*option domain_list}"
				line="$(echo "$line" | sed 's/^[[:space:]]*//')"
				payload="${line#\'}"
				if [ "$payload" != "$line" ]; then
					case "$payload" in
						*\'*)
							payload="${payload%%\'*}"
							payload="$(normalize_domain_list_text "$payload")"
							[ -n "$payload" ] && echo "${prefix}option domain_list '${payload}'" >> "$tmp"
							in_domain=0
							payload=""
							continue
							;;
					esac
				else
					payload=""
				fi
				continue
				;;
		esac
		if [ "$in_domain" -eq 1 ]; then
			line="$(trim_line "$line")"
			case "$line" in
				\'*\')
					line="${line#\'}"
					line="${line%\'}"
					[ -n "$payload" ] && payload="${payload},${line}" || payload="$line"
					payload="$(normalize_domain_list_text "$payload")"
					[ -n "$payload" ] && echo "${prefix}option domain_list '${payload}'" >> "$tmp"
					in_domain=0
					payload=""
					continue
					;;
				*)
					[ -n "$line" ] && payload="${payload:+$payload,}${line}"
					continue
					;;
			esac
		fi
		echo "$line" >> "$tmp"
	done < "$WDtt_CFG"

	if [ "$in_domain" -eq 1 ] && [ -n "$payload" ]; then
		payload="$(normalize_domain_list_text "$payload")"
		[ -n "$payload" ] && echo "${prefix}option domain_list '${payload}'" >> "$tmp"
	fi

	mv "$tmp" "$WDtt_CFG"
	log "normalized multiline domain_list"
}

fix_multiline_hashes() {
	local tmp line in_hashes=0 payload="" prefix=""

	if grep -E "^[[:space:]]*option hashes '[^']+'[[:space:]]*$" "$WDtt_CFG" >/dev/null 2>&1; then
		return 0
	fi
	grep -q 'option hashes' "$WDtt_CFG" 2>/dev/null || return 0

	tmp="$(mktemp /tmp/wdtt-fix.XXXXXX)"
	while read -r line || [ -n "$line" ]; do
		case "$line" in
			*"option hashes"*)
				in_hashes=1
				prefix="${line%%option hashes*}"
				line="${line#*option hashes}"
				line="$(echo "$line" | sed "s/^[[:space:]]*//")"
				payload="${line#\'}"
				if [ "$payload" != "$line" ]; then
					case "$payload" in
						*\'*)
							payload="${payload%%\'*}"
							echo "${prefix}option hashes '${payload}'" >> "$tmp"
							in_hashes=0
							payload=""
							continue
							;;
					esac
				else
					payload="${line#\"}"
					payload="${payload%%\"*}"
					if [ -n "$payload" ] && [ "$line" != "$payload" ]; then
						echo "${prefix}option hashes '${payload}'" >> "$tmp"
						in_hashes=0
						payload=""
						continue
					fi
					payload=""
				fi
				continue
				;;
		esac
		if [ "$in_hashes" -eq 1 ]; then
			part="$(echo "$line" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//; s/^'\''//; s/'\''$//; s/,$//')"
			[ -z "$part" ] && continue
			case "$line" in
				*\'*)
					part="${part%%\'*}"
					[ -n "$payload" ] && payload="${payload},${part}" || payload="$part"
					echo "${prefix}option hashes '${payload}'" >> "$tmp"
					in_hashes=0
					payload=""
					continue
					;;
			esac
			[ -n "$payload" ] && payload="${payload},${part}" || payload="$part"
			continue
		fi
		echo "$line" >> "$tmp"
	done < "$WDtt_CFG"

	if [ "$in_hashes" -eq 1 ] && [ -n "$payload" ]; then
		echo "${prefix}option hashes '${payload}'" >> "$tmp"
	fi

	mv "$tmp" "$WDtt_CFG"
	log "normalized multiline hashes"
}

fix_option_domain_lines
fix_globals_list_domains
fix_multiline_domain_list
fix_multiline_hashes
migrate_rules_to_domain_list
purge_ghost_list_domains_from_file
for _sec in $(grep -E "^config rule" "$WDtt_CFG" 2>/dev/null | sed "s/^config rule ['\"]\\([^'\"]*\\)['\"].*/\\1/"); do
	sanitize_rule_domain_list_uci "$_sec"
done
[ -x /sbin/uci ] && uci -q commit wdtt 2>/dev/null

if [ -x /sbin/uci ] && ! uci show wdtt 2>&1 | grep -qi 'parse error'; then
	val="$(uci -q get wdtt.globals.hashes 2>/dev/null)" || val=""
	if [ -n "$val" ]; then
		val="$(printf '%s' "$val" | tr '\n\r\t ' ',' | sed 's/,,*/,/g; s/^,//; s/,$//')"
		uci -q set "wdtt.globals.hashes=${val}"
		uci -q commit wdtt 2>/dev/null
	fi
fi

if uci show wdtt 2>&1 | grep -qi 'parse error'; then
	log "WARN: uci parse error remains"
	exit 1
fi

log "OK: config normalized"
exit 0
