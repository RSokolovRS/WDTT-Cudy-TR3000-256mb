#!/bin/sh
# Полная диагностика и починка WDTT selective routing

IFACE="$(uci -q get wdtt.globals.iface 2>/dev/null)"
IFACE="${IFACE:-wg-wdtt}"

echo "=== WDTT doctor ==="

if [ -x /usr/libexec/wdtt/fix-config ]; then
	/usr/libexec/wdtt/fix-config || true
else
	echo "WARN: fix-config missing — sh install.sh"
fi

echo "--- routing script ---"
if grep -q 'parse_list_domain_line' /usr/libexec/wdtt/routing 2>/dev/null \
	&& grep -q 'WDTT_ROUTING_VERSION=3.7' /usr/libexec/wdtt/routing 2>/dev/null \
	&& ! grep -q '|| echo 0)"' /usr/libexec/wdtt/routing 2>/dev/null \
	&& grep -q 'return 0' /usr/libexec/wdtt/routing 2>/dev/null; then
	echo "OK: routing script"
else
	echo "FAIL: routing устарел (нужен v3.7.2+) — sh /tmp/wdtt-install.sh или:"
	echo "  uclient-fetch -O /usr/libexec/wdtt/routing \\"
	echo "    https://raw.githubusercontent.com/RSokolovRS/WDTT-Cudy-TR3000-256mb/main/wdtt-client/files/wdtt-routing"
	echo "  chmod 755 /usr/libexec/wdtt/routing"
fi

echo "--- uci ---"
if uci show wdtt 2>&1 | grep -qi 'parse error'; then
	echo "FAIL: uci parse error (часто multiline hashes)"
	uci show wdtt 2>&1 | head -3
else
	echo "OK: uci parse"
	echo "hashes: $(uci -q get wdtt.globals.hashes 2>/dev/null | cut -c1-40)..."
	echo "captcha_mode: $(uci -q get wdtt.globals.captcha_mode 2>/dev/null)"
	echo "vk_auth_mode: $(uci -q get wdtt.globals.vk_auth_mode 2>/dev/null)"
	echo "package_version: $(tr -d '\r\n' < /usr/share/wdtt/version 2>/dev/null || echo unknown)"
fi

echo "--- dnsmasq ---"
if command -v dnsmasq >/dev/null 2>&1 && dnsmasq --version 2>/dev/null | grep -qi nftset; then
	echo "OK: dnsmasq nftset"
else
	echo "FAIL: нужен dnsmasq-full (не обычный dnsmasq):"
	echo "  apk del dnsmasq && apk add dnsmasq-full && /etc/init.d/dnsmasq restart"
fi
echo "confdir=$(uci -q get dhcp.@dnsmasq[0].confdir 2>/dev/null)"
if grep -rq wdtt /var/etc/dnsmasq* 2>/dev/null; then
	echo "OK: wdtt.conf подключён в generated dnsmasq config"
else
	echo "WARN: wdtt.conf не виден в /var/etc/dnsmasq* — /etc/init.d/dnsmasq restart"
fi

echo "--- wireguard ---"
if ip link show "$IFACE" >/dev/null 2>&1; then
	echo "OK: $IFACE up"
else
	echo "WARN: $IFACE down — routing reload может не создать table 100"
	echo "      Сначала LuCI → Подключить (connected), потом doctor снова"
fi

echo "--- reload routing ---"
/usr/libexec/wdtt/routing reload "$IFACE" 2>&1 || true

echo ""
/usr/libexec/wdtt/routing status 2>/dev/null || echo "routing status failed"

echo ""
has_wdtt_domains() {
	uci show wdtt 2>/dev/null | grep -qE '\.domain=' && return 0
	grep -qE '^[[:space:]]*list domain[[:space:]]' /etc/config/wdtt 2>/dev/null && return 0
	return 1
}

echo "=== rule type check ==="
rule_type="$(uci -q get wdtt.route1.type 2>/dev/null)"
if has_wdtt_domains; then
	if [ "$rule_type" = "exclusion" ]; then
		echo "FAIL: route1 type=exclusion — домены идут НАПРЯМУЮ, не в туннель"
		echo "      uci set wdtt.route1.type='route' && uci commit wdtt"
		echo "      /usr/libexec/wdtt/routing reload $IFACE"
	elif [ "$rule_type" = "route" ] || [ -z "$rule_type" ]; then
		echo "OK: rule type=route (домены в туннель)"
	else
		echo "WARN: route1 type=${rule_type:-?}"
	fi
	enabled="$(uci -q get wdtt.route1.enabled 2>/dev/null)"
	if [ "$enabled" = "0" ]; then
		echo "FAIL: route1 enabled=0 — правило ВЫКЛЮЧЕНО"
		echo "      uci set wdtt.route1.enabled='1' && uci commit wdtt"
	fi
else
	echo "FAIL: нет list domain — добавьте домены в LuCI → Правила"
	echo "      uci add_list wdtt.route1.domain=2ip.ru"
	echo "      uci add_list wdtt.route1.domain=youtube.com"
fi

echo ""
echo "=== ghost check ==="
if grep -qE 'nftset=/(2iw\.|yoltlbe\.com|2iw\.rl)/' /tmp/dnsmasq.d/wdtt.conf 2>/dev/null; then
	echo "FAIL: wdtt.conf содержит ghost-домены (2iw.* / yoltlbe.com)"
	echo "      uci -q delete wdtt.route1.domain; uci add_list wdtt.route1.domain=2ip.ru"
	echo "      uci add_list wdtt.route1.domain=youtube.com; uci commit wdtt"
	echo "      /usr/libexec/wdtt/fix-config && /usr/libexec/wdtt/routing reload $IFACE"
elif grep -q '^nftset=' /tmp/dnsmasq.d/wdtt.conf 2>/dev/null; then
	echo "OK: wdtt.conf домены выглядят нормально"
else
	echo "WARN: wdtt.conf пуст — добавьте домены в LuCI → Правила"
fi

state="$(cat /var/run/wdtt/routing.mode 2>/dev/null || echo missing)"
if [ "$state" = "selective" ]; then
	echo "OK: routing active (state_file=selective)"
else
	echo "FAIL: state_file=$state (policy routing не применился)"
fi

echo ""
echo "=== Чеклист ==="
echo "1) LuCI: Правила → list domain (2ip.io, youtube.com), Включено, Save & Apply"
echo "2) Подключить → connected"
echo "3) /usr/libexec/wdtt/doctor — wdtt_route IPs: 1+, state_file=selective"
echo "4) С LAN-клиента: curl -4 https://2ip.io (DNS=роутер, DoH off)"
