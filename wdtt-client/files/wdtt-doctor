#!/bin/sh
# Полная диагностика WDTT (selective + full tunnel)

IFACE="$(uci -q get wdtt.globals.iface 2>/dev/null)"
IFACE="${IFACE:-wg-wdtt}"
ROUTING_MODE="$(uci -q get wdtt.globals.routing_mode 2>/dev/null)"
ROUTING_MODE="${ROUTING_MODE:-selective}"

echo "=== WDTT doctor ==="
echo "routing_mode=${ROUTING_MODE}"

if [ -x /usr/libexec/wdtt/fix-config ]; then
	/usr/libexec/wdtt/fix-config || true
else
	echo "WARN: fix-config missing — sh install.sh"
fi

echo "--- routing script ---"
if grep -q 'parse_list_domain_line' /usr/libexec/wdtt/routing 2>/dev/null \
	&& grep -q 'WDTT_ROUTING_VERSION=3.7' /usr/libexec/wdtt/routing 2>/dev/null \
	&& ! grep -q '|| echo 0)"' /usr/libexec/wdtt/routing 2>/dev/null \
	&& grep -q 'return 0' /usr/libexec/wdtt/routing 2>/dev/null; then
	echo "OK: routing script"
else
	echo "FAIL: routing устарел (нужен v3.7.2+) — sh /tmp/wdtt-install.sh"
fi

echo "--- uci ---"
if uci show wdtt 2>&1 | grep -qi 'parse error'; then
	echo "FAIL: uci parse error (часто multiline hashes)"
	uci show wdtt 2>&1 | head -3
else
	echo "OK: uci parse"
	echo "hashes: $(uci -q get wdtt.globals.hashes 2>/dev/null | cut -c1-40)..."
	echo "captcha_mode: $(uci -q get wdtt.globals.captcha_mode 2>/dev/null)"
	echo "vk_auth_mode: $(uci -q get wdtt.globals.vk_auth_mode 2>/dev/null)"
	echo "package_version: $(tr -d '\r\n' < /usr/share/wdtt/version 2>/dev/null || echo unknown)"
fi

echo "--- dnsmasq ---"
if [ "$ROUTING_MODE" = "full" ]; then
	echo "SKIP: dnsmasq nftset не нужен в режиме full"
else
	if command -v dnsmasq >/dev/null 2>&1 && dnsmasq --version 2>/dev/null | grep -qi nftset; then
		echo "OK: dnsmasq nftset"
	else
		echo "FAIL: нужен dnsmasq-full:"
		echo "  apk del dnsmasq && apk add dnsmasq-full && /etc/init.d/dnsmasq restart"
	fi
	echo "confdir=$(uci -q get dhcp.@dnsmasq[0].confdir 2>/dev/null)"
	if grep -rq wdtt /var/etc/dnsmasq* 2>/dev/null; then
		echo "OK: wdtt.conf подключён в generated dnsmasq config"
	else
		echo "WARN: wdtt.conf не виден в /var/etc/dnsmasq* — /etc/init.d/dnsmasq restart"
	fi
fi

echo "--- wireguard ---"
if ip link show "$IFACE" >/dev/null 2>&1; then
	echo "OK: $IFACE up"
else
	echo "WARN: $IFACE down — сначала LuCI → Подключить"
fi

	if [ "$ROUTING_MODE" = "full" ]; then
	echo "--- full tunnel ---"
	/usr/libexec/wdtt/routing stop 2>/dev/null || true
	if ip link show "$IFACE" >/dev/null 2>&1; then
		[ -x /usr/libexec/wdtt/full-tunnel ] && /usr/libexec/wdtt/full-tunnel apply 2>/dev/null || true
	else
		mkdir -p /var/run/wdtt
		printf '%s\n' "full" > /var/run/wdtt/routing.mode
	fi
	if ip route show 0.0.0.0/1 2>/dev/null | grep -q "dev $IFACE"; then
		echo "OK: route 0.0.0.0/1 dev $IFACE"
	else
		echo "FAIL: нет route 0.0.0.0/1 dev $IFACE"
	fi
	if ip route show 128.0.0.0/1 2>/dev/null | grep -q "dev $IFACE"; then
		echo "OK: route 128.0.0.0/1 dev $IFACE"
	else
		echo "FAIL: нет route 128.0.0.0/1 dev $IFACE"
	fi
	if nft list chain inet fw4 srcnat 2>/dev/null | grep -q "oifname \"$IFACE\""; then
		echo "OK: masquerade oifname $IFACE"
	else
		echo "WARN: нет masquerade на $IFACE — sh /etc/firewall.wdtt && fw4 reload"
	fi
	if sysctl -n net.ipv4.ip_forward 2>/dev/null | grep -q '^1$'; then
		echo "OK: ip_forward=1"
	else
		echo "WARN: ip_forward=0 — sysctl -w net.ipv4.ip_forward=1"
	fi
else
	echo "--- reload routing (selective) ---"
	/usr/libexec/wdtt/routing reload "$IFACE" 2>&1 || true
fi

echo ""
/usr/libexec/wdtt/routing status 2>/dev/null || echo "routing status failed"

echo ""
has_wdtt_domains() {
	uci show wdtt 2>/dev/null | grep -qE '\.domain_list=' && return 0
	grep -qE '^[[:space:]]*option domain_list[[:space:]]' /etc/config/wdtt 2>/dev/null && return 0
	return 1
}

if [ "$ROUTING_MODE" = "full" ]; then
	echo "=== full tunnel check ==="
	state="$(tr -d '\r\n' < /var/run/wdtt/routing.mode 2>/dev/null || echo missing)"
	if [ "$state" = "full" ]; then
		echo "OK: state_file=full"
	elif [ "$state" = "selective" ]; then
		echo "FAIL: state_file=selective при routing_mode=full — doctor только что остановил selective"
		echo "      LuCI Save & Apply → Переподключить"
	else
		echo "WARN: state_file=${state}"
	fi
else
	echo "=== rule type check ==="
	rules_ok=0
	for section in $(uci -q show wdtt 2>/dev/null | sed -n "s/^wdtt\.\\([^.=]*\\)=rule\$/\\1/p"); do
		rule_type="$(uci -q get "wdtt.${section}.type" 2>/dev/null)"
		enabled="$(uci -q get "wdtt.${section}.enabled" 2>/dev/null)"
		domains="$(uci -q get "wdtt.${section}.domain_list" 2>/dev/null)"
		echo "rule ${section}: type=${rule_type:-route} enabled=${enabled:-1} domains=${domains:-(empty)}"
		[ "$rule_type" = "exclusion" ] && echo "  FAIL: type=exclusion — домены идут напрямую"
		[ "$enabled" = "0" ] && [ -n "$domains" ] && echo "  FAIL: enabled=0 — включите правило в LuCI"
		[ -n "$domains" ] && [ "$enabled" != "0" ] && rules_ok=1
	done
	if ! has_wdtt_domains; then
		echo "FAIL: нет domain_list — LuCI → Правила → Домены → «Принять изменения»"
	elif [ "$rules_ok" -eq 0 ]; then
		echo "FAIL: нет активного route-правила с доменами"
	else
		echo "OK: route-правила с доменами найдены"
	fi

	echo ""
	echo "=== ghost check ==="
	if grep -qE 'nftset=/(2iw\.|yoltlbe\.com|2iw\.rl)/' /tmp/dnsmasq.d/wdtt.conf 2>/dev/null; then
		echo "FAIL: wdtt.conf содержит ghost-домены"
	elif grep -q '^nftset=' /tmp/dnsmasq.d/wdtt.conf 2>/dev/null; then
		echo "OK: wdtt.conf домены выглядят нормально"
	else
		echo "WARN: wdtt.conf пуст — «Принять изменения» в LuCI или routing reload"
	fi

	state="$(tr -d '\r\n' < /var/run/wdtt/routing.mode 2>/dev/null || echo missing)"
	if [ "$state" = "selective" ]; then
		echo "OK: routing active (state_file=selective)"
	else
		echo "FAIL: state_file=${state} (policy routing не применился)"
	fi
fi

echo ""
echo "=== Чеклист ==="
if [ "$ROUTING_MODE" = "full" ]; then
	echo "1) LuCI: Режим «Полный» → Save & Apply внизу страницы"
	echo "2) Переподключить (Отключить → Подключить)"
	echo "3) doctor: state_file=full, default route через wg-wdtt"
	echo "4) curl -4 https://2ip.io с LAN-клиента"
else
	echo "1) LuCI: Правила → Домены, Включено → «Принять изменения»"
	echo "2) Подключить → connected"
	echo "3) doctor — wdtt_route IPs: 1+, state_file=selective"
	echo "4) curl -4 https://2ip.io с LAN-клиента (DNS=роутер, DoH off)"
fi
