
config globals 'globals'
	option enabled '0'
	option peer ''
	option password ''
	option hashes ''
	option workers '12'
	option mtu '1380'
	option listen '127.0.0.1:9000'
	option turn_host ''
	option turn_port ''
	option captcha_mode 'wv'
	option vk_auth_mode 'vkcalls'
	option device_id ''
	option iface 'wg-wdtt'
	# selective = как Podkop (списки в туннель, остальное напрямую)
	# full = весь трафик роутера через WDTT
	option routing_mode 'selective'

# Пустое правило — домены в LuCI → «Домены» (option domain_list, не list domain)
config rule 'route1'
	option enabled '0'
	option type 'route'
	# option domain_list 'youtube.com,2ip.ru'

