#!/bin/sh /etc/rc.common
# WDTT VPN client — procd service

START=90
STOP=10
USE_PROCD=1

start_service() {
	local enabled
	config_load wdtt
	config_get enabled globals enabled 0
	[ "$enabled" = "1" ] || return 0

	mkdir -p /var/run/wdtt

	procd_open_instance
	procd_set_param command /usr/sbin/wdttd
	procd_set_param respawn 3600 5 0
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param file /etc/config/wdtt
	procd_close_instance
}

stop_service() {
	/usr/libexec/wdtt/routing stop 2>/dev/null
}

service_triggers() {
	procd_add_reload_trigger wdtt
}

reload_service() {
	[ -x /usr/libexec/wdtt/fix-config ] && /usr/libexec/wdtt/fix-config 2>/dev/null || true
	stop
	start
}
