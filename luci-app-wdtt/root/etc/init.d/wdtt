#!/bin/sh /etc/rc.common
# WDTT VPN client — procd service

START=90
STOP=10
USE_PROCD=1

start_service() {
	local enabled
	config_load wdtt
	config_get enabled globals enabled 0
	[ "$enabled" = "1" ] || return 0

	mkdir -p /var/run/wdtt

	procd_open_instance
	procd_set_param command /usr/sbin/wdttd
	procd_set_param respawn 3600 5 0
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param file /etc/config/wdtt
	procd_close_instance
}

stop_service() {
	/usr/libexec/wdtt/routing stop 2>/dev/null
	# procd SIGTERM иногда не успевает при captcha wait — добиваем явно
	killall wdttd 2>/dev/null
}

service_triggers() {
	procd_add_reload_trigger wdtt
}

reload_service() {
	# UCI reload: правила / режим маршрутизации, туннель не рвём
	[ -x /usr/libexec/wdtt/fix-config ] && /usr/libexec/wdtt/fix-config 2>/dev/null || true
	local mode iface
	mode="$(uci -q get wdtt.globals.routing_mode 2>/dev/null)"
	iface="$(uci -q get wdtt.globals.iface 2>/dev/null)"
	iface="${iface:-wg-wdtt}"
	mkdir -p /var/run/wdtt
	if [ "$mode" = "full" ]; then
		/usr/libexec/wdtt/routing stop 2>/dev/null || true
		if ip link show "$iface" >/dev/null 2>&1; then
			[ -x /usr/libexec/wdtt/full-tunnel ] && /usr/libexec/wdtt/full-tunnel apply 2>/dev/null || true
		else
			printf '%s\n' "full" > /var/run/wdtt/routing.mode
		fi
	elif ip link show "$iface" >/dev/null 2>&1; then
		/usr/libexec/wdtt/routing reload "$iface" 2>/dev/null || true
	fi
}
