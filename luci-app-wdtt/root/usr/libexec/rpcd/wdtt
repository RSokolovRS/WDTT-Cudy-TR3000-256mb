#!/bin/sh
# rpcd ubus plugin for WDTT status

. /lib/functions.sh
. /usr/share/libubox/jshn.sh

STATUS_FILE="/var/run/wdtt/status.json"
LOG_FILE="/var/run/wdtt/wdtt.log"

wdtt_connect() {
	uci -q set wdtt.globals.enabled='1' || return 1
	uci -q commit wdtt || return 1
	/etc/init.d/wdtt restart 2>/dev/null || /etc/init.d/wdtt start 2>/dev/null
	return 0
}

wdtt_uci_parse_ok() {
	uci show wdtt 2>&1 | grep -qi 'parse error' && return 1
	return 0
}

wdtt_uci_line_value() {
	local line="$1" val
	val="${line#*\'}"
	if [ "$val" != "$line" ]; then
		val="${val%%\'*}"
		printf '%s' "$val"
		return 0
	fi
	val="${line#*\"}"
	val="${val%%\"*}"
	printf '%s' "$val"
}

wdtt_rule_section_name() {
	local line="$1" section
	section="${line#config rule }"
	section="${section#\'}"; section="${section%%\'*}"
	if [ "$section" = "${line#config rule }" ]; then
		section="${section#\"}"; section="${section%%\"*}"
	fi
	section="${section%% *}"
	printf '%s' "$section"
}

wdtt_rule_json_entry() {
	local section="$1" type="$2" enabled="$3" domains="$4"
	[ -n "$section" ] || return 0
	json_add_object
	json_add_string name "$section"
	json_add_string type "${type:-route}"
	json_add_string enabled "${enabled:-1}"
	json_add_string domains "${domains:-}"
	json_close_object
}

wdtt_rule_info_cb() {
	local section="$1"
	local type enabled domains

	type="$(uci -q get "wdtt.${section}.type" 2>/dev/null)"
	enabled="$(uci -q get "wdtt.${section}.enabled" 2>/dev/null)"
	[ -z "$enabled" ] && enabled="1"
	domains="$(uci -q get "wdtt.${section}.domain_list" 2>/dev/null)"
	wdtt_rule_json_entry "$section" "$type" "$enabled" "$domains"
}

wdtt_rules_from_file() {
	local line section="" type="route" enabled="1" domains="" in_rule=0 val

	[ -r /etc/config/wdtt ] || return 0

	while read -r line || [ -n "$line" ]; do
		line="${line#"${line%%[![:space:]]*}"}"
		line="${line%"${line##*[![:space:]]}"}"
		case "$line" in
			""|\#*) continue ;;
			config\ rule\ *)
				[ -n "$section" ] && wdtt_rule_json_entry "$section" "$type" "$enabled" "$domains"
				section="$(wdtt_rule_section_name "$line")"
				type="route"
				enabled="1"
				domains=""
				in_rule=1
				continue
				;;
			config\ *)
				[ -n "$section" ] && wdtt_rule_json_entry "$section" "$type" "$enabled" "$domains"
				section=""
				domains=""
				in_rule=0
				continue
				;;
		esac
		[ "$in_rule" -eq 1 ] || continue
		case "$line" in
			option\ type\ *)
				type="$(wdtt_uci_line_value "$line")"
				;;
			option\ enabled\ *)
				enabled="$(wdtt_uci_line_value "$line")"
				;;
			option\ domain_list\ *)
				val="$(wdtt_uci_line_value "$line")"
				[ -n "$domains" ] && [ -n "$val" ] && domains="$domains,$val"
				[ -z "$domains" ] && domains="$val"
				;;
			list\ domain|list\ domain\ *|list\ domains|list\ domains\ *)
				val="${line#list domain}"
				val="${val#list domains}"
				val="${val#"${val%%[![:space:]]*}"}"
				val="${val#\'}"; val="${val%%\'*}"
				if [ "$val" = "$line" ]; then
					val="${val#\"}"; val="${val%%\"*}"
				fi
				[ -n "$val" ] || continue
				[ -n "$domains" ] && domains="$domains,$val"
				[ -z "$domains" ] && domains="$val"
				;;
		esac
	done < /etc/config/wdtt
	[ -n "$section" ] && wdtt_rule_json_entry "$section" "$type" "$enabled" "$domains"
}

wdtt_routing_info() {
	local n iface uci_ok=1

	iface="$(uci -q get wdtt.globals.iface 2>/dev/null)"
	iface="${iface:-wg-wdtt}"

	wdtt_uci_parse_ok || uci_ok=0

	json_init
	json_add_string routing_mode "$(uci -q get wdtt.globals.routing_mode 2>/dev/null)"
	json_add_string state_file "$(tr -d '\r\n' < /var/run/wdtt/routing.mode 2>/dev/null || echo missing)"
	json_add_boolean uci_parse_ok "$uci_ok"
	n=$(nft list set inet wdtt wdtt_route 2>/dev/null | grep -cE '^\s+[0-9]+\.[0-9]+') || n=0
	json_add_int route_ips "$n"
	json_add_array rules
	if [ "$uci_ok" -eq 1 ]; then
		config_load wdtt
		config_foreach wdtt_rule_info_cb rule
	elif [ -r /etc/config/wdtt ]; then
		wdtt_rules_from_file
	fi
	json_close_array
	json_dump
}

wdtt_apply_config() {
	local iface mode
	[ -x /usr/libexec/wdtt/fix-config ] && /usr/libexec/wdtt/fix-config 2>/dev/null || true
	mode="$(uci -q get wdtt.globals.routing_mode 2>/dev/null)"
	iface="$(uci -q get wdtt.globals.iface 2>/dev/null)"
	iface="${iface:-wg-wdtt}"
	if [ "$mode" != "full" ] && ip link show "$iface" >/dev/null 2>&1; then
		/usr/libexec/wdtt/routing reload "$iface" 2>/dev/null || true
	fi
	return 0
}

wdtt_apply_rules() {
	wdtt_apply_config
}

wdtt_disconnect() {
	uci -q set wdtt.globals.enabled='0' || return 1
	uci -q commit wdtt || return 1
	/etc/init.d/wdtt stop 2>/dev/null
	killall wdttd 2>/dev/null
	return 0
}

case "$1" in
	list)
		echo '{ "status": {}, "logs": { "tail": 100 }, "captcha": { "token": "" }, "connect": {}, "disconnect": {}, "apply_config": {}, "apply_rules": {}, "routing_info": {} }'
		;;
	call)
		method="${2:-}"
		case "$method" in
			status)
				pkg_ver="unknown"
				[ -r /usr/share/wdtt/version ] && pkg_ver=$(tr -d '\r\n' < /usr/share/wdtt/version | head -c 32)
				wdttd_ver=""
				[ -x /usr/sbin/wdttd ] && wdttd_ver=$(/usr/sbin/wdttd -version 2>/dev/null | tr -d '\r\n' | head -c 32)

				if [ -f "$STATUS_FILE" ]; then
					json_load "$(cat "$STATUS_FILE")"
				else
					json_init
					json_add_boolean running 0
					json_add_string state "stopped"
					json_add_int rx_bytes 0
					json_add_int tx_bytes 0
					json_add_int workers 0
					json_add_boolean wg_applied 0
				fi
				json_add_string package_version "$pkg_ver"
				[ -n "$wdttd_ver" ] && json_add_string wdttd_version "$wdttd_ver"
				json_dump
				;;
			logs)
				json_load "$(cat)"
				json_get_var tail tail
				tail="${tail:-100}"
				json_init
				json_add_array lines
				if [ -f "$LOG_FILE" ]; then
					tmp="$(mktemp /tmp/wdtt-rpcd-log.XXXXXX)"
					tail -n "$tail" "$LOG_FILE" > "$tmp"
					while IFS= read -r line || [ -n "$line" ]; do
						json_add_string "" "$line"
					done < "$tmp"
					rm -f "$tmp"
				fi
				json_close_array
				json_dump
				;;
			captcha)
				json_load "$(cat)"
				json_get_var token token
				if [ -n "$token" ]; then
					/usr/sbin/wdttd -captcha "$token" 2>/dev/null
					json_init
					json_add_string result "ok"
					json_dump
				else
					json_init
					json_add_string error "empty token"
					json_dump
				fi
				;;
			connect)
				if wdtt_connect; then
					json_init
					json_add_string result "ok"
					json_add_string enabled "1"
					json_dump
				else
					json_init
					json_add_string error "connect failed"
					json_dump
				fi
				;;
			disconnect)
				if wdtt_disconnect; then
					json_init
					json_add_string result "ok"
					json_add_string enabled "0"
					json_dump
				else
					json_init
					json_add_string error "disconnect failed"
					json_dump
				fi
				;;
			apply_config)
				if wdtt_apply_config; then
					json_init
					json_add_string result "ok"
					json_dump
				else
					json_init
					json_add_string error "apply_config failed"
					json_dump
				fi
				;;
			apply_rules)
				if wdtt_apply_rules; then
					json_init
					json_add_string result "ok"
					json_dump
				else
					json_init
					json_add_string error "apply_rules failed"
					json_dump
				fi
				;;
			routing_info)
				wdtt_routing_info
				;;
		esac
		;;
esac
